NODE_ENV=development
PORT=5000

# MongoDB connection mode:
# local = use MONGO_URI_LOCAL
# atlas = use MONGO_URI_ATLAS
# direct = use MONGO_URI directly
MONGO_MODE=local

MONGO_URI=mongodb://localhost:27017/ai-cms
MONGO_URI_LOCAL=mongodb://localhost:27017/ai-cms
MONGO_URI_ATLAS=mongodb+srv://<username>:<password>@<cluster-url>/ai-cms?retryWrites=true&w=majority

JWT_SECRET=replace-with-strong-secret-for-development
JWT_EXPIRES_IN=7d

# Comma-separated values are supported, for example:
# CORS_ORIGIN=http://localhost:5173,http://192.168.1.10:5173
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
API_PREFIX=/api/v1
APP_NAME=AI-CMS Backend
LOG_LEVEL=info
DB_CONNECT_TIMEOUT_MS=2500

SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@aicms.local
SEED_ADMIN_PASSWORD=Admin123!

AI_SERVICE_URL=http://localhost:8000
NOTIFICATION_PROVIDER=mock
ENABLE_MOCK_NOTIFICATIONS=true
UPLOAD_DIR=uploads
PRESCRIPTION_PDF_DIR=uploads/prescriptions
INVOICE_STORAGE_DIR=storage/invoices
PUBLIC_API_BASE_URL=http://localhost:5000
GST_DEFAULT_RATE=18
