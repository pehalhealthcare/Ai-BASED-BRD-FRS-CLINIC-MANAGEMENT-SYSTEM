COMPOSE_PROJECT_NAME=ai_cms

BACKEND_PORT=5000
FRONTEND_PORT=5173
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=0.0.0.0
MONGO_PORT=27017

MONGO_INITDB_DATABASE=ai-cms

NODE_ENV=development
MONGO_MODE=local
MONGO_URI_LOCAL=mongodb://mongo:27017/ai-cms
MONGO_URI_ATLAS=mongodb+srv://<username>:<password>@<cluster-url>/ai-cms?retryWrites=true&w=majority
MONGO_URI=mongodb://mongo:27017/ai-cms

JWT_SECRET=replace-with-strong-secret-for-development
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
BACKEND_API_URL=http://backend:5000/api/v1

AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_NAME=ai-cms-ai-service
NOTIFICATION_PROVIDER=mock
ENABLE_MOCK_NOTIFICATIONS=true
MODEL_PROVIDER=placeholder
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=mock-medical-json
LLM_TIMEOUT_SECONDS=20
ENABLE_LLM=true
STT_PROVIDER=faster_whisper
OCR_PROVIDER=paddleocr
OCR_FALLBACK_PROVIDER=tesseract
DRUG_DATA_PROVIDER=local
MODEL_MODE=rule_based_mvp
MODEL_DIR=app/models
ENABLE_HEAVY_MODELS=false
ENABLE_MODEL_DOWNLOADS=false
ENABLE_AI_FALLBACKS=true
ENABLE_PHARMACY_FORECAST=true
PHARMACY_FORECAST_MIN_RECORDS=30
BILLING_ANOMALY_MIN_TRAINING_RECORDS=300
AI_AUDIT_LOG_PATH=storage/ai_audit.jsonl
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
MAX_AUDIO_MB=25
AUDIO_TEMP_DIR=./tmp/audio
ENABLE_STT=true
WHISPER_ENABLED=false
OCR_ENABLED=true
OCR_MAX_FILE_MB=10
OCR_MAX_PDF_PAGES=5
OCR_LANGUAGE=en
OCR_ENABLE_HINDI=false
MASK_SENSITIVE_FIELDS=true
OCR_CONFIDENCE_REVIEW_THRESHOLD=0.85
DOCUMENT_TEMP_DIR=./tmp/documents
MAX_UPLOAD_MB=10
NO_SHOW_MODEL_DIR=app/models/no_show
NO_SHOW_MIN_TRAINING_ROWS=100
NO_SHOW_ENABLE_TRAINING=true
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_AI_BASE_URL=http://localhost:8000/api/v1

API_PREFIX=/api/v1
APP_NAME=AI-CMS Backend
LOG_LEVEL=info
DB_CONNECT_TIMEOUT_MS=2500
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@aicms.local
SEED_ADMIN_PASSWORD=Admin123!
UPLOAD_DIR=uploads
PRESCRIPTION_PDF_DIR=uploads/prescriptions
INVOICE_STORAGE_DIR=storage/invoices
PUBLIC_API_BASE_URL=http://localhost:5000
GST_DEFAULT_RATE=18
AI_MEDICAL_DISCLAIMER="AI assistance is not a final diagnosis or prescription. Doctor approval is mandatory."
